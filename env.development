# 开发环境配置
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_DATABASE=quant_navigator_dev
DB_SSL=false

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# LLM API配置
QWEN_API_KEY=your_qwen_api_key_here
WENXIN_API_KEY=your_wenxin_api_key_here

# 数据源配置
TUSHARE_TOKEN=your_tushare_token_here

# 应用配置
APP_DEBUG=true
APP_LOG_LEVEL=debug
APP_CACHE_ENABLED=false
APP_MOCK_SERVICES=true
APP_HOT_RELOAD=true
