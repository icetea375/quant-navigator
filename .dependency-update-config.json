{
  "update_strategy": {
    "security": {
      "enabled": true,
      "priority": 1,
      "auto_merge": true,
      "notification": true
    },
    "patch": {
      "enabled": true,
      "priority": 2,
      "auto_merge": false,
      "notification": true
    },
    "minor": {
      "enabled": true,
      "priority": 3,
      "auto_merge": false,
      "notification": true
    },
    "major": {
      "enabled": false,
      "priority": 4,
      "auto_merge": false,
      "notification": true
    }
  },
  "conflict_resolution": {
    "strategy": "smart",
    "max_retries": 3,
    "fallback_strategy": "manual",
    "exclude_packages": [
      "react",
      "react-dom",
      "typescript"
    ]
  },
  "testing": {
    "run_tests": true,
    "test_commands": [
      "pnpm test:unit",
      "pnpm test:backend",
      "python -m pytest tests/ -v"
    ],
    "coverage_threshold": 80
  },
  "notifications": {
    "slack": {
      "enabled": false,
      "webhook_url": ""
    },
    "email": {
      "enabled": false,
      "recipients": []
    },
    "github": {
      "enabled": true,
      "create_issues": true,
      "assignees": []
    }
  },
  "schedule": {
    "security_scan": "0 9 * * 1",
    "dependency_check": "0 9 * * 2",
    "update_application": "0 9 * * 3"
  },
  "exclusions": {
    "packages": [
      "quant-navigator-backend"
    ],
    "patterns": [
      "*-alpha",
      "*-beta",
      "*-rc"
    ]
  }
}
