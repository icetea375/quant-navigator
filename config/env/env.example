# 量化导航仪环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 基础配置
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/quant_navigator
REDIS_URL=redis://localhost:6379

# Tushare数据源配置
TUSHARE_TOKEN=your_tushare_pro_token_here
TUSHARE_BASE_URL=http://api.tushare.pro

# 商业LLM API配置
# 通义千问 (阿里云)
TONGYI_API_KEY=your_tongyi_api_key_here
TONGYI_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# 通义千问3模型配置
QWEN_API_KEY=sk-f8972859c3fc4226bc3a4c17f9b91ffe
QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# 文心一言 (百度)
WENXIN_API_KEY=your_wenxin_api_key_here
WENXIN_BASE_URL=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop

# LLM通用配置
LLM_TIMEOUT=30000
LLM_MAX_RETRIES=3
LLM_MAX_CONCURRENT=5

# 量化信号计算配置
Z_SCORE_THRESHOLD=2.5
ROLLING_WINDOW_SIZE=90
MACRO_RISK_CALCULATION_ENABLED=true
STYLE_ROTATION_CALCULATION_ENABLED=true

# 异常检测配置
ANOMALY_DETECTION_ENABLED=true
ANOMALY_THRESHOLD=2.5
ANOMALY_DETECTION_INTERVAL=300000

# 仲裁配置
AUTO_ARBITRATION_THRESHOLD=0.8
HUMAN_REVIEW_REQUIRED=true
NOTIFICATION_ENABLED=true

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# 缓存配置
CACHE_TTL=300
CACHE_MAX_SIZE=1000
