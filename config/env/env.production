# 生产环境配置
NODE_ENV=production

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_production_password
DB_DATABASE=quant_navigator_prod
DB_SSL=true

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# LLM API配置
QWEN_API_KEY=your_production_qwen_api_key
WENXIN_API_KEY=your_production_wenxin_api_key

# 数据源配置
TUSHARE_TOKEN=your_production_tushare_token

# 应用配置
APP_DEBUG=false
APP_LOG_LEVEL=info
APP_CACHE_ENABLED=true
APP_MOCK_SERVICES=false
APP_HOT_RELOAD=false

# 监控配置
MONITORING_ENABLED=true
MONITORING_INTERVAL=60000
