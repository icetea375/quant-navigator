{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting - 遵循测试宪法第4条 */
    "strict": true,
    "noUnusedLocals": false, // 允许未使用的局部变量（开发阶段）
    "noUnusedParameters": false, // 允许未使用的参数（开发阶段）
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true, // 保持严格性
    "strictNullChecks": true // 保持严格性
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
