{
  "name": "@quant-navigator/backend",
  "version": "1.0.0",
  "description": "量化导航仪后端 - 模块化单体架构",
  "private": true,
  "scripts": {
    "dev": "python -m uvicorn src.main:app --reload",
    "start": "python -m uvicorn src.main:app --host 0.0.0.0 --port 8000",
    "test": "pytest",
    "test:unit": "pytest tests/unit/",
    "test:integration": "pytest tests/integration/",
    "test:e2e": "pytest tests/e2e/",
    "lint": "black src/ && isort src/",
    "type-check": "mypy src/"
  },
  "dependencies": {
    "@quant-navigator/shared-types": "workspace:*"
  }
}
