{
  "name": "@quant-navigator/monorepo",
  "version": "13.3.0",
  "description": "量化导航仪Monorepo - 模块化单体架构",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --parallel --filter './packages/*' build",
    "backend:dev": "pnpm --filter '@quant-navigator/backend' dev",
    "backend:start": "pnpm --filter '@quant-navigator/backend' start",
    "test": "pnpm --recursive test",
    "test:unit": "pnpm --filter './tools/tests' test:unit",
    "test:integration": "pnpm --filter './tools/tests' test:integration",
    "test:e2e": "pnpm --filter './tools/tests' test:e2e",
    "test:coverage": "pnpm -r --stream run test:coverage",
    "test:backend": "pnpm --filter './packages/backend-python' test-cov",
    "test:frontend": "pnpm --filter './packages/frontend-main' test:coverage && pnpm --filter './packages/frontend-aigc' test:coverage",
    "lint": "pnpm --recursive lint",
    "lint:fix": "pnpm --recursive lint:fix",
    "type-check": "pnpm --recursive type-check",
    "format": "pnpm --recursive format",
    "format:check": "pnpm --recursive format:check",
    "docs:check": "source venv/bin/activate && python tools/scripts/check_docs_quality.py",
    "docs:generate": "source venv/bin/activate && python tools/scripts/generate_docs.py",
    "arch:scan": "dependency-cruiser packages --config .dependency-cruiser.js",
    "arch:scan:dot": "dependency-cruiser packages --config .dependency-cruiser.js --output-type dot | dot -T svg > architecture-graph.svg",
    "clean": "pnpm --recursive clean && rm -rf node_modules",
    "install:all": "pnpm install"
  },
  "keywords": [
    "quantitative-analysis",
    "tdd",
    "test-driven-development",
    "ai-governance",
    "financial-analysis"
  ],
  "author": "AI Assistant",
  "license": "MIT",
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "glob": "^11.0.3",
    "graphviz": "^0.0.9",
    "jest": "^29.6.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tools/tests"
    ],
    "testMatch": [
      "<rootDir>/tools/tests/**/*.test.ts",
      "<rootDir>/tools/tests/**/*.spec.ts",
      "<rootDir>/tools/tests/**/*.test.tsx",
      "<rootDir>/tools/tests/**/*.spec.tsx"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    },
    "collectCoverageFrom": [
      "packages/**/*.{ts,tsx}",
      "!packages/**/*.d.ts",
      "!packages/**/*.stories.{ts,tsx}",
      "!packages/**/*.test.{ts,tsx}",
      "!packages/**/*.spec.{ts,tsx}"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "setupFilesAfterEnv": [
      "<rootDir>/tools/tests/config/jest-setup.ts"
    ]
  }
}
