{
  "name": "papa-test-suite",
  "version": "1.0.0",
  "description": "智能分析系统全流程测试套件",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:backend": "jest --testPathPattern=backend",
    "test:frontend": "jest --testPathPattern=frontend",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "setup": "node scripts/setup-test-env.js",
    "cleanup": "node scripts/cleanup-test-data.js"
  },
  "dependencies": {
    "ts-jest": "^29.4.4",
    "@nestjs/testing": "^10.4.20",
    "supertest": "^6.3.4",
    "express": "^4.18.2",
    "@types/supertest": "^2.0.16",
    "@types/express": "^4.17.21"
  }
}
