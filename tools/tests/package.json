{
  "name": "papa-test-suite",
  "version": "1.0.0",
  "description": "智能分析系统全流程测试套件",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:backend": "jest --testPathPattern=backend",
    "test:frontend": "jest --testPathPattern=frontend",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "setup": "node scripts/setup-test-env.js",
    "cleanup": "node scripts/cleanup-test-data.js",
    "e2e:install": "playwright install",
    "e2e:install-deps": "playwright install-deps"
  },
  "dependencies": {
    "@quant-navigator/shared-types": "workspace:*",
    "ts-jest": "^29.4.4",
    "@nestjs/testing": "^10.4.20",
    "supertest": "^6.3.4",
    "express": "^4.18.2",
    "@types/supertest": "^2.0.16",
    "@types/express": "^4.17.21",
    "vitest": "^1.0.0",
    "@vue/test-utils": "^2.4.0",
    "vue": "^3.3.0",
    "@vitejs/plugin-vue": "^4.4.0",
    "@types/node": "^20.0.0",
    "jsdom": "^23.0.0",
    "@playwright/test": "^1.40.0"
  }
}
