    it('点击刷新按钮应该重新加载所有数据', async () => {
      const { adminApi } = await import('@/services/admin')
      
})
})
      adminApi.getSystemLogs.mockResolvedValue([])

      const refreshButton = wrapper.find('.refresh-button')
      if (refreshButton.exists()) {
        await refreshButton.trigger('click')
        await wrapper.vm.$nextTick()

        expect(adminApi.getSystemStatus).toHaveBeenCalledTimes(2) // 初始加载 + 刷新
        expect(adminApi.getSystemMetrics).toHaveBeenCalledTimes(2)
        expect(adminApi.getSystemLogs).toHaveBeenCalledTimes(2)
      }
})
})

