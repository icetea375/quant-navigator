/**
 * SystemBrainConsole.vue 视图测试
 * 
 * 遵循测试宪法原则：
 * - 第1条：测试的唯一目的是验证生产代码是否严格履行了其设计契约
 * - 第3条："红灯-绿灯-重构"原则
 * - 第7条：断言必须"精确且有意义"
 * - 第10条：环境一致性铁律
 */

import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest'
import { mount, VueWrapper } from '@vue/test-utils'
import { createPinia, setActivePinia } from 'pinia'
import SystemBrainConsole from '@/views/admin/SystemBrainConsole.vue'
import { useAuthStore } from '@/stores/auth'
import { useAdminStore } from '@/stores/admin'

// 模拟Element Plus图标
vi.mock("@element-plus/icons-vue", () => ({
  Setting: { template: '<i class="setting-icon"></i>' },
  Monitor: { template: '<i class="monitor-icon"></i>' },
  DataAnalysis: { template: '<i class="data-analysis-icon"></i>' },
  Refresh: { template: '<i class="refresh-icon"></i>' },
  Warning: { template: '<i class="warning-icon"></i>' },
  Success: { template: '<i class="success-icon"></i>' },
  Error: { template: '<i class="error-icon"></i>' },
  InfoFilled: { template: '<i class="info-filled-icon"></i>' },
  SuccessFilled: { template: '<i class="success-filled-icon"></i>' },
  Close: { template: '<i class="close-icon"></i>' }
}))

// 模拟logger
vi.mock('@/utils/logger', () => ({
  logger: {
    error: vi.fn(),
    info: vi.fn(),
    warn: vi.fn()
  }
}))

// 模拟API服务
vi.mock('@/services/admin', () => ({
  adminApi: {
    getSystemStatus: vi.fn(),
    getSystemMetrics: vi.fn(),
    getSystemLogs: vi.fn(),
    updateSystemConfig: vi.fn(),
    restartSystem: vi.fn(),
    getSystemHealth: vi.fn()
  }
}))

describe('SystemBrainConsole.vue', () => {
  let wrapper: VueWrapper<any>
  let authStore: any
  let adminStore: any

  beforeEach(() => {
    // 设置Pinia
    setActivePinia(createPinia())
    authStore = useAuthStore()
    adminStore = useAdminStore()
    
    // 重置认证状态
    authStore.isAuthenticated = true
    authStore.user = { name: '管理员', email: 'admin@example.com', role: 'admin' }
    vi.clearAllMocks()
  })

  afterEach(() => {
    if (wrapper) {
      wrapper.unmount()
    }
  })

