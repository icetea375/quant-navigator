})

    it('应该正确显示CPU使用率', () => {
      wrapper.vm.systemStatus = { cpu: 75 }
      expect(wrapper.vm.systemStatus.cpu).toBe(75)
})

    it('应该正确显示内存使用率', () => {
      wrapper.vm.systemStatus = { memory: 60 }
      expect(wrapper.vm.systemStatus.memory).toBe(60)
})

    it('应该正确显示磁盘使用率', () => {
      wrapper.vm.systemStatus = { disk: 30 }
      expect(wrapper.vm.systemStatus.disk).toBe(30)
})
