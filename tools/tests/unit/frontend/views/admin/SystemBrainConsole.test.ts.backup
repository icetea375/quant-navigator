})

    it('应该加载系统日志', async () => {
      const { adminApi } = await import('@/services/admin')
      const mockLogs = [
        { id: 1, level: 'info', message: '系统启动', timestamp: '2024-01-15 10:00:00' },
        { id: 2, level: 'warning', message: '内存使用率较高', timestamp: '2024-01-15 10:05:00' }
      ]
      
      adminApi.getSystemLogs.mockResolvedValue(mockLogs)

      await wrapper.vm.loadSystemLogs()
      await wrapper.vm.$nextTick()

      expect(adminApi.getSystemLogs).toHaveBeenCalled()
      expect(wrapper.vm.systemLogs).toEqual(mockLogs)
})

    it('应该正确显示日志级别', () => {
      wrapper.vm.systemLogs = [
        { id: 1, level: 'error', message: '系统错误', timestamp: '2024-01-15 10:00:00' },
        { id: 2, level: 'info', message: '系统信息', timestamp: '2024-01-15 10:01:00' }
      ]

      expect(wrapper.vm.systemLogs[0].level).toBe('error')
      expect(wrapper.vm.systemLogs[1].level).toBe('info')
})
})

