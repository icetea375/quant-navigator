            }
          }
})
      }).not.toThrow()
})

    it('当API调用失败时应该记录错误并继续运行', async () => {
      wrapper = mount(SystemBrainConsole, {
        global: {
          stubs: {
            'el-container': { template: '<div class="el-container"><slot /></div>' },
            'el-header': { template: '<header><slot /></header>' },
            'el-main': { template: '<main><slot /></main>' },
            'el-card': { template: '<div class="el-card"><slot /></div>' },
            'el-button': { template: '<button><slot /></button>' },
            'el-table': { template: '<table><slot /></table>' },
            'el-table-column': { template: '<td><slot /></td>' },
            'el-tabs': { template: '<div class="el-tabs"><slot /></div>' },
            'el-tab-pane': { template: '<div class="el-tab-pane"><slot /></div>' },
            'el-progress': { template: '<div class="el-progress"></div>' },
            'el-alert': { template: '<div class="el-alert"><slot /></div>' },
            'el-icon': { template: '<i><slot /></i>' },
            'el-loading': { template: '<div v-if="loading">Loading...</div>' }
          }
        }
})

      const { adminApi } = await import('@/services/admin')
      const error = new Error('网络错误')
      
      adminApi.getSystemStatus.mockRejectedValue(error)

      await wrapper.vm.loadSystemStatus()
      await wrapper.vm.$nextTick()

      const { logger } = await import('@/utils/logger')
      expect(logger.error).toHaveBeenCalledWith('Failed to load system status:', error)
      expect(wrapper.vm.loading).toBe(false)
})
})
})
