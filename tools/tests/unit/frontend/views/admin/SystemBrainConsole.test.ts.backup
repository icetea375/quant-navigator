})
})

    it('点击重启按钮应该确认重启', async () => {
      // 模拟确认对话框
      window.confirm = vi.fn().mockReturnValue(true)
      
      await wrapper.vm.handleRestartSystem()
      
      expect(window.confirm).toHaveBeenCalledWith('确定要重启系统吗？这将影响所有用户。')
})

    it('确认重启应该调用重启API', async () => {
      const { adminApi } = await import('@/services/admin')
      
})
      window.confirm = vi.fn().mockReturnValue(true)

      await wrapper.vm.handleRestartSystem()
      await wrapper.vm.$nextTick()

      expect(adminApi.restartSystem).toHaveBeenCalled()
})

    it('取消重启应该不执行重启操作', async () => {
      const { adminApi } = await import('@/services/admin')
      
      window.confirm = vi.fn().mockReturnValue(false)

      await wrapper.vm.handleRestartSystem()
      await wrapper.vm.$nextTick()

      expect(adminApi.restartSystem).not.toHaveBeenCalled()
})
})

