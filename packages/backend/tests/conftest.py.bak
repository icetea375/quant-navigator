# 测试数据工厂
@pytest.fixture
def arbitration_case_factory():
    """仲裁案件数据工厂"""
    def _create_case(**kwargs):
        default_case = {
            "case_id": f"case_{kwargs.get('case_id', '001')}",
            "report_type": kwargs.get('report_type', 'fact_analysis'),
            "target_code": kwargs.get('target_code', '000001.SZ'),
            "qwen_analysis": kwargs.get('qwen_analysis', {}),
            "doubao_analysis": kwargs.get('doubao_analysis', {}),
            "disagreement_score": kwargs.get('disagreement_score', 0.0),
            "status": kwargs.get('status', 'pending'),
            "created_at": kwargs.get('created_at', '2025-01-26T10:00:00Z')
        }
        default_case.update(kwargs)
        return default_case
    return _create_case


@pytest.fixture
def report_factory():
    """报告数据工厂"""
    def _create_report(**kwargs):
        default_report = {
            "report_id": f"report_{kwargs.get('report_id', '001')}",
            "report_type": kwargs.get('report_type', 'daily_analysis'),
            "target_code": kwargs.get('target_code', '000001.SZ'),
            "report_date": kwargs.get('report_date', '2025-01-26'),
            "content": kwargs.get('content', '测试报告内容'),
            "status": kwargs.get('status', 'completed'),
            "created_at": kwargs.get('created_at', '2025-01-26T10:00:00Z')
        }
        default_report.update(kwargs)
        return default_report
    return _create_report
