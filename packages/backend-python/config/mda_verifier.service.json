{
  "mda_verifier": {
    "llm_provider": "qwen_plus",
    "confidence_threshold": 0.7,
    "max_retries": 3,
    "timeout": 30,
    "prompt_templates": {
      "verification": "mda_verification_prompts.json",
      "analysis": "mda_analysis_prompts.json"
    },
    "validation_rules": {
      "min_content_length": 100,
      "max_content_length": 10000,
      "required_sections": ["经营情况", "财务状况", "风险因素"]
    }
  }
}
