{
  "app": {
    "name": "量化导航仪",
    "version": "1.0.0",
    "description": "智能投资分析平台",
    "debug": false,
    "logLevel": "info"
  },
  "database": {
    "host": "localhost",
    "port": 5432,
    "username": "postgres",
    "password": "password",
    "database": "quant_navigator",
    "ssl": false,
    "pool": {
      "min": 2,
      "max": 10
    }
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "password": "",
    "db": 0,
    "maxMemory": "512mb",
    "maxMemoryPolicy": "allkeys-lru"
  },
  "llm": {
    "providers": {
      "qwen_plus": {
        "api_key": "your_qwen_api_key_here",
        "base_url": "https://dashscope.aliyuncs.com/api/v1",
        "model": "qwen-plus",
        "description": "效果、速度、成本均衡"
      },
      "qwen_max": {
        "api_key": "your_qwen_api_key_here",
        "base_url": "https://dashscope.aliyuncs.com/api/v1",
        "model": "qwen-max",
        "description": "适合复杂任务，能力最强"
      },
      "qwen_flash": {
        "api_key": "your_qwen_api_key_here",
        "base_url": "https://dashscope.aliyuncs.com/api/v1",
        "model": "qwen-turbo",
        "description": "适合简单任务，速度快、成本低"
      }
    },
    "default_provider": "qwen_plus",
    "timeout": 30,
    "max_retries": 3
  },
  "analysis": {
    "taskScheduler": {
      "maxConcurrent": 5,
      "retryAttempts": 3,
      "retryDelay": 5000,
      "cleanupInterval": 300000
    },
    "newsClassifier": {
      "categories": ["AI", "医药", "宏观", "科技", "金融"],
      "confidenceThreshold": 0.6,
      "batchSize": 100
    },
    "summaryGenerator": {
      "maxLength": 500,
      "minLength": 100,
      "temperature": 0.7
    }
  },
  "quant_engine": {
    "z_score_threshold": 2.5,
    "rolling_window": 90,
    "macro_risk_enabled": true,
    "style_rotation_enabled": true
  },
  "event_chain_builder": {
    "llm_provider": "qwen_plus",
    "max_chain_length": 10,
    "confidence_threshold": 0.7
  },
  "prediction_generator": {
    "llm_provider": "qwen_plus",
    "scenario_count": 3,
    "confidence_threshold": 0.6
  },
  "causal_validator": {
    "llm_provider": "qwen_plus",
    "consistency_threshold": 0.8
  },
  "anomaly_thresholds": {
    "z_score_threshold": 2.5,
    "confidence_threshold": 0.6,
    "ai_disagreement_threshold": 0.7,
    "risk_levels": {
      "LOW": 0.3,
      "MEDIUM": 0.6,
      "HIGH": 0.8,
      "CRITICAL": 0.9
    }
  },
  "arbitration": {
    "auto_arbitration_threshold": 0.8,
    "human_review_required": true,
    "notification_enabled": true
  },
  "data_sources": {
    "tushare": {
      "token": "your_tushare_token_here",
      "enabled": true,
      "priority": 1
    },
    "xueqiu": {
      "enabled": true,
      "priority": 2
    },
    "eastmoney": {
      "enabled": false,
      "priority": 3
    }
  }
}
