# 量化导航仪前端环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 应用基础配置
VITE_APP_TITLE=量化导航仪
VITE_APP_VERSION=10.1
VITE_APP_ENV=development

# API配置
VITE_API_BASE_URL=http://localhost:3001/api/v1
VITE_API_TIMEOUT=30000
VITE_API_RETRY_COUNT=3

# 后端服务配置
VITE_BACKEND_HOST=localhost
VITE_BACKEND_PORT=3001
VITE_BACKEND_PROTOCOL=http

# WebSocket配置
VITE_WS_URL=ws://localhost:3001/ws
VITE_WS_RECONNECT_INTERVAL=5000
VITE_WS_MAX_RECONNECT_ATTEMPTS=5

# 认证配置
VITE_JWT_SECRET=your_jwt_secret_here
VITE_JWT_EXPIRES_IN=7d
VITE_REFRESH_TOKEN_EXPIRES_IN=30d

# 第三方服务配置
VITE_TUSHARE_TOKEN=your_tushare_token_here
VITE_TUSHARE_BASE_URL=http://api.tushare.pro

# LLM服务配置
VITE_LLM_PROVIDER=tongyi
VITE_LLM_API_KEY=your_llm_api_key_here
VITE_LLM_BASE_URL=https://dashscope.aliyuncs.com/api/v1
VITE_LLM_MODEL=qwen-turbo
VITE_LLM_TIMEOUT=30000

# 缓存配置
VITE_CACHE_TTL=300000
VITE_CACHE_MAX_SIZE=1000
VITE_CACHE_PREFIX=quant_navigator

# 日志配置
VITE_LOG_LEVEL=debug
VITE_LOG_ENABLE_CONSOLE=true
VITE_LOG_ENABLE_REMOTE=false
VITE_LOG_REMOTE_URL=http://localhost:3001/api/v1/logs

# 功能开关
VITE_ENABLE_DEBUG=true
VITE_ENABLE_MOCK=false
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=true

# 主题配置
VITE_THEME=light
VITE_PRIMARY_COLOR=#1890ff
VITE_SUCCESS_COLOR=#52c41a
VITE_WARNING_COLOR=#faad14
VITE_ERROR_COLOR=#f5222d

# 分页配置
VITE_PAGE_SIZE=20
VITE_PAGE_SIZE_OPTIONS=10,20,50,100
VITE_MAX_PAGE_SIZE=1000

# 图表配置
VITE_CHART_ANIMATION=true
VITE_CHART_RESPONSIVE=true
VITE_CHART_THEME=default

# 文件上传配置
VITE_UPLOAD_MAX_SIZE=10485760
VITE_UPLOAD_ALLOWED_TYPES=.xlsx,.xls,.csv,.pdf,.txt
VITE_UPLOAD_URL=http://localhost:3001/api/v1/upload

# 导出配置
VITE_EXPORT_MAX_ROWS=10000
VITE_EXPORT_FORMATS=xlsx,csv,pdf
VITE_EXPORT_URL=http://localhost:3001/api/v1/export

# 监控配置
VITE_MONITOR_ENABLED=true
VITE_MONITOR_SAMPLE_RATE=0.1
VITE_MONITOR_REPORT_URL=http://localhost:3001/api/v1/monitor

# 开发工具配置
VITE_DEVTOOLS_ENABLED=true
VITE_DEVTOOLS_PORT=8098
VITE_DEVTOOLS_HOST=localhost

# 测试配置
VITE_TEST_MODE=false
VITE_TEST_API_MOCK=true
VITE_TEST_DATA_PATH=/test-data

# 国际化配置
VITE_I18N_LOCALE=zh-CN
VITE_I18N_FALLBACK_LOCALE=en-US
VITE_I18N_LOAD_PATH=/locales

# 路由配置
VITE_ROUTER_MODE=history
VITE_ROUTER_BASE=/
VITE_ROUTER_SCROLL_BEHAVIOR=smooth

# 构建配置
VITE_BUILD_SOURCEMAP=true
VITE_BUILD_MINIFY=true
VITE_BUILD_DROP_CONSOLE=false
VITE_BUILD_DROP_DEBUGGER=true

# 部署配置
VITE_PUBLIC_PATH=/
VITE_OUTPUT_DIR=dist
VITE_ASSETS_DIR=assets

# 代理配置
VITE_PROXY_ENABLED=true
VITE_PROXY_TARGET=http://localhost:3001
VITE_PROXY_CHANGE_ORIGIN=true
VITE_PROXY_WS=true
